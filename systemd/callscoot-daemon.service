[Unit]
Description=CallScoot Bluetooth phone audio bridge
After=pipewire.service pipewire-pulse.service wireplumber.service
Wants=pipewire.service pipewire-pulse.service wireplumber.service

[Service]
Type=simple
ExecStart=/usr/bin/python3 %h/.local/lib/callscoot/callscoot.py daemon
Restart=always
RestartSec=2

[Install]
WantedBy=default.target
