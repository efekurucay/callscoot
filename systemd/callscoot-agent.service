[Unit]
Description=CallScoot AI call agent
After=pipewire.service pipewire-pulse.service wireplumber.service callscoot-daemon.service
Wants=pipewire.service pipewire-pulse.service wireplumber.service

[Service]
Type=simple
ExecStart=/usr/bin/python3 %h/.local/lib/callscoot/callscoot_agent.py run
Restart=always
RestartSec=2

[Install]
WantedBy=default.target
